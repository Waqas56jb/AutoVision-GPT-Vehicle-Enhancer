# ─────────────────────────────────────────────────────────────
# AutoVision GPT — Server Environment Variables
# Copy this file to ".env" and fill in your real values.
# ─────────────────────────────────────────────────────────────

# Your OpenAI API key (required). Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenAI image model used for editing / compositing.
# gpt-image-1 is the state-of-the-art multimodal image model.
OPENAI_IMAGE_MODEL=gpt-image-1

# Output image size: 1024x1024 | 1536x1024 (landscape) | 1024x1536 (portrait) | auto
OPENAI_IMAGE_SIZE=1536x1024

# Output quality: low | medium | high | auto
OPENAI_IMAGE_QUALITY=high

# How hard the model works to reproduce the FEATURES of the uploaded car rather
# than re-imagining them. The OpenAI default is "low" — which is what produced
# redesigned headlights, altered grilles and, in one case, a different model of
# car entirely. Keep this on "high".
# Supported by gpt-image-1 and gpt-image-1.5. NOT supported by gpt-image-2.
OPENAI_INPUT_FIDELITY=high

# Sorts each upload into exterior / interior / detail so the correct prompt runs
# (a dashboard must not be composited onto a showroom floor). Fraction of a cent
# per photo; never touches the delivered pixels.
OPENAI_VISION_MODEL=gpt-4o-mini

# How many times the OpenAI SDK retries a rate-limited (429) call with
# exponential backoff before giving up. Raise this if you run large batches.
OPENAI_MAX_RETRIES=5

# Per-request timeout in ms. One high-quality edit takes ~60s.
OPENAI_TIMEOUT_MS=180000

# Server
PORT=5000
NODE_ENV=development

# CORS is PUBLIC — any origin may call this API from a browser, so there is no
# CLIENT_ORIGIN to configure. Deploy the frontend anywhere and it just works.
#
# Trade-off: an open origin means any web page can spend this account's OpenAI
# credits. The real protections are RATE_LIMIT_MAX below and MAX_UPLOAD_MB
# (CORS never stopped direct curl calls anyway). To lock down later, add an API
# key rather than an origin allow-list.

# Max upload size per file in megabytes
MAX_UPLOAD_MB=25

# Rate limiting (per IP). NOTE: a batch sends one request PER IMAGE, so a
# 100-vehicle run is 100+ requests from a single dealer's IP. Keep this above
# your largest expected batch or the server will 429 its own users.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=600
