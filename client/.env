# ─────────────────────────────────────────────────────────────
# Shared defaults — loaded in BOTH dev and production builds.
# Production-only values live in .env.production (which overrides this file).
# ─────────────────────────────────────────────────────────────

# Leave EMPTY here on purpose. In local dev the Vite proxy forwards "/api" to
# http://localhost:5000, so `npm run dev` talks to YOUR local server.
# The deployed backend URL is set in .env.production, not here — otherwise
# local development would silently hit the live Railway backend.
VITE_API_BASE_URL=

# How many vehicles render SIMULTANEOUSLY. Batch time ≈
#   ceil(images / VITE_BATCH_CONCURRENCY) × 60s
# Raise this to your OpenAI account's images-per-minute limit for gpt-image-1
# (platform.openai.com → Settings → Limits). Beyond that you just collect 429s.
VITE_BATCH_CONCURRENCY=6
