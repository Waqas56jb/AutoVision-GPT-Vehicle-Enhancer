# ─────────────────────────────────────────────────────────────
# Production build only (`npm run build`, and every Vercel deploy).
# Vite bakes these in at BUILD time — changing them needs a rebuild/redeploy.
# Overrides .env for the production mode.
# ─────────────────────────────────────────────────────────────

# The deployed backend (Railway).
VITE_API_BASE_URL=https://meticulous-cat-production-60c6.up.railway.app

# Keep in step with the OpenAI account's images-per-minute limit.
VITE_BATCH_CONCURRENCY=6
