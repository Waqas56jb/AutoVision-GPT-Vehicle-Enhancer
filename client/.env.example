# ─────────────────────────────────────────────────────────────
# AutoVision GPT — Client environment
#
# Vite loads, in order (later overrides earlier):
#   .env                → both dev and production
#   .env.production     → `npm run build` / every Vercel deploy
#   .env.development    → `npm run dev`
#
# Everything here is baked in at BUILD time. Changing a value on the hosting
# dashboard does nothing until you REDEPLOY.
# ─────────────────────────────────────────────────────────────

# ── Local development (.env) ───────────────────────────────────
# Leave EMPTY. The Vite proxy forwards "/api" to http://localhost:5000, so
# `npm run dev` talks to your local server. Putting the live URL here would make
# local development silently hit production.
VITE_API_BASE_URL=

# ── Production (.env.production) ───────────────────────────────
# The deployed backend, e.g.
# VITE_API_BASE_URL=https://meticulous-cat-production-60c6.up.railway.app

# ── Batch speed ────────────────────────────────────────────────
# How many vehicles render SIMULTANEOUSLY. Batch time ≈
#   ceil(images / VITE_BATCH_CONCURRENCY) × 60s
# so 20 images at 6 lanes ≈ 4 waves ≈ 4 minutes, not 20.
#
# The hard ceiling is your OpenAI account's images-per-minute limit for
# gpt-image-1 (platform.openai.com → Settings → Limits), NOT this app. Set this
# to that number to go as fast as the account allows; anything more just
# collects 429s (which the app retries and backs off from automatically).
VITE_BATCH_CONCURRENCY=6
