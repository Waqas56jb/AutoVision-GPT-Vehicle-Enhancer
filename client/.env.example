# ── Local development ──────────────────────────────────────────
# Leave EMPTY in local dev — the Vite proxy forwards "/api" to localhost:5000.
# VITE_API_BASE_URL=

# ── Production (Vercel) ────────────────────────────────────────
# Set this to your deployed backend URL (the server Vercel project), e.g.
# VITE_API_BASE_URL=https://autovision-server.vercel.app
VITE_API_BASE_URL=
