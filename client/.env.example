# ── Local development ──────────────────────────────────────────
# Leave EMPTY in local dev — the Vite proxy forwards "/api" to localhost:5000.
# VITE_API_BASE_URL=

# ── Production (Vercel) ────────────────────────────────────────
# Set this to your deployed backend URL (the server Vercel project), e.g.
# VITE_API_BASE_URL=https://autovision-server.vercel.app
VITE_API_BASE_URL=

# ── Batch speed ────────────────────────────────────────────────
# How many vehicles are rendered SIMULTANEOUSLY. Batch time is roughly
#   ceil(images / VITE_BATCH_CONCURRENCY) × 60 seconds
# so 20 images at 6 lanes ≈ 4 waves ≈ 4 minutes, not 20.
#
# The hard ceiling is your OpenAI account's images-per-minute limit for
# gpt-image-1 (platform.openai.com → Settings → Limits), NOT this app. Set this
# to that number to go as fast as your account physically allows; anything more
# just collects 429s (which the app retries and backs off from automatically).
VITE_BATCH_CONCURRENCY=6
